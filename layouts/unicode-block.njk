{% extends "page.njk" %}
{% block head %}
{{ super() }}
<style>
.unicode-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}
.unicode-cell {
  width: 4em;
  height: 4em;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid #ccc;
  cursor: pointer;
  font-family: monospace;
  user-select: none;
  transition: background 0.15s;
}
.unicode-cell:hover {
  background: #e8e8e8;
}
.unicode-cell.copied {
  background: #c8e6c9;
}
.unicode-char {
  font-size: 1.8em;
  line-height: 1.5;
}
.unicode-code {
  font-size: 0.6em;
  color: #888;
}
</style>
{% endblock %}
{% block pagecontent %}
<p><a href="{{ data.blockUrl }}">Unicode Block: {{ data.blockName }}</a></p>
<div id="unicode-grid" class="unicode-grid"></div>
{% endblock %}
{% block bodyend %}
{{ super() }}
<script>
(function () {
  var grid = document.getElementById('unicode-grid');
  for (var cp = {{ data.start }}; cp <= {{ data.end }}; cp++) {
    var ch = String.fromCodePoint(cp);
    var code = 'U+' + cp.toString(16).toUpperCase().padStart(4, '0');
    var cell = document.createElement('div');
    cell.className = 'unicode-cell';
    cell.title = code;
    cell.innerHTML =
      '<span class="unicode-char">' + ch + '</span>' +
      '<span class="unicode-code">' + code + '</span>';
    cell.addEventListener('click', (function (c, el) {
      return function () {
        navigator.clipboard.writeText(c).then(function () {
          el.classList.add('copied');
          setTimeout(function () { el.classList.remove('copied'); }, 600);
        });
      };
    })(ch, cell));
    grid.appendChild(cell);
  }
}());
</script>
{% endblock %}
