---
title: Unicode
layout: page
blocks:
  - name: Block Elements
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Block%20Elements%7D
    start: 0x2580
    end: 0x259F
  - name: Box Drawing
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Box%20Drawing%7D
    start: 0x2500
    end: 0x257F
  - name: Geometric Shapes
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Geometric%20Shapes%7D
    start: 0x25A0
    end: 0x25FF
  - name: Greek And Coptic
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Greek%20And%20Coptic%7D
    start: 0x0370
    end: 0x03FF
  - name: Latin-1 Supplement
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Latin-1%20Supplement%7D
    start: 0x0080
    end: 0x00FF
  - name: Mathematical Operators
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Mathematical%20Operators%7D
    start: 0x2200
    end: 0x22FF
  - name: Superscripts And Subscripts
    url: https://util.unicode.org/UnicodeJsps/list-unicodeset.jsp?a=%5Cp%7BBlock=Superscripts%20And%20Subscripts%7D
    start: 0x2070
    end: 0x209F
---
<style>
.unicode-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 1em;
}
.unicode-cell {
  width: 4em;
  height: 4em;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid #ccc;
  cursor: pointer;
  font-family: monospace;
  user-select: none;
  transition: background 0.15s;
}
.unicode-cell:hover {
  background: #e8e8e8;
}
.unicode-cell.active {
  background: #d0e8ff;
  border-color: #888;
}
.unicode-char {
  font-size: 1.8em;
  line-height: 1.5;
}
.unicode-code {
  font-size: 0.6em;
  color: #888;
}
.unicode-detail {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 2px solid #ccc;
  padding: 0.8em 1.5em;
  display: none;
  gap: 1em;
  align-items: center;
  flex-wrap: wrap;
  box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
  z-index: 100;
}
.unicode-detail.visible {
  display: flex;
}
.unicode-detail-char {
  font-size: 3em;
  font-family: monospace;
  min-width: 1.2em;
  text-align: center;
  line-height: 1;
}
.unicode-detail-fields {
  flex: 1;
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.15em 0.8em;
  font-size: 0.9em;
  font-family: monospace;
}
.unicode-detail-label {
  color: #888;
  text-align: right;
  white-space: nowrap;
  font-family: sans-serif;
}
.unicode-detail-copy {
  cursor: pointer;
}
</style>
<p>
  <label for="block-select">Block:</label>
  <select id="block-select">
    {% for block in data.blocks %}
    <option value="{{ loop.index0 }}">{{ block.name }}</option>
    {% endfor %}
  </select>
  <a id="block-link" href="{{ data.blocks[0].url }}" target="_blank">Unicode reference</a>
</p>
<div id="unicode-grid" class="unicode-grid"></div>
<div id="unicode-detail" class="unicode-detail">
  <div class="unicode-detail-char" id="detail-char"></div>
  <div class="unicode-detail-fields" id="detail-fields"></div>
  <button class="unicode-detail-copy" id="detail-copy">Copy</button>
</div>
<script>
(function () {
  var blocks = {{ data.blocksJson | safe }};
  var select = document.getElementById('block-select');
  var blockLink = document.getElementById('block-link');
  var grid = document.getElementById('unicode-grid');
  var detail = document.getElementById('unicode-detail');
  var detailChar = document.getElementById('detail-char');
  var detailFields = document.getElementById('detail-fields');
  var detailCopy = document.getElementById('detail-copy');
  var activeCell = null;
  var activeChar = null;

  function renderGrid(blockIndex) {
    var block = blocks[blockIndex];
    grid.innerHTML = '';
    detail.classList.remove('visible');
    if (activeCell) activeCell.classList.remove('active');
    activeCell = null;
    activeChar = null;
    blockLink.href = block.url;
    for (var cp = block.start; cp <= block.end; cp++) {
      var ch = String.fromCodePoint(cp);
      var code = 'U+' + cp.toString(16).toUpperCase().padStart(4, '0');
      var info = block.chars[String(cp)];
      var cell = document.createElement('div');
      cell.className = 'unicode-cell';
      cell.title = code + (info ? '\n' + info.name : '');
      cell.innerHTML =
        '<span class="unicode-char">' + ch + '</span>' +
        '<span class="unicode-code">' + code + '</span>';
      cell.addEventListener('click', (function (c, code, el, chars) {
        return function (e) {
          e.stopPropagation();
          if (activeCell) activeCell.classList.remove('active');
          activeCell = el;
          activeChar = c;
          el.classList.add('active');
          showDetail(c, code, chars);
        };
      })(ch, code, cell, block.chars));
      grid.appendChild(cell);
    }
  }

  function showDetail(ch, code, chars) {
    var info = chars[String(ch.codePointAt(0))] || {};
    detailChar.textContent = ch;
    detailFields.innerHTML = '';
    var rows = [
      ['Code point', code],
      ['Name', info.name],
      ['LaTeX', info.latex],
      ['HTML', info.html],
      ['MathML', info.mathml]
    ];
    rows.forEach(function (row) {
      if (!row[1]) return;
      var label = document.createElement('span');
      label.className = 'unicode-detail-label';
      label.textContent = row[0];
      var value = document.createElement('span');
      value.textContent = row[1];
      detailFields.appendChild(label);
      detailFields.appendChild(value);
    });
    detail.classList.add('visible');
  }

  select.addEventListener('change', function () {
    renderGrid(parseInt(select.value, 10));
  });

  detailCopy.addEventListener('click', function () {
    if (!activeChar) return;
    navigator.clipboard.writeText(activeChar).then(function () {
      var orig = detailCopy.textContent;
      detailCopy.textContent = 'Copied!';
      setTimeout(function () { detailCopy.textContent = orig; }, 800);
    });
  });

  document.addEventListener('click', function () {
    detail.classList.remove('visible');
    if (activeCell) activeCell.classList.remove('active');
    activeCell = null;
    activeChar = null;
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      detail.classList.remove('visible');
      if (activeCell) activeCell.classList.remove('active');
      activeCell = null;
      activeChar = null;
    }
  });

  detail.addEventListener('click', function (e) {
    e.stopPropagation();
  });

  renderGrid(0);
}());
</script>
